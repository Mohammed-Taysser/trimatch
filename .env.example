# Copy to .env — REQUIRED. There are no fallback defaults anywhere: docker compose
# and the api both fail loudly if a variable is missing, so gaps are visible.
NODE_ENV=development
API_PORT=3000

# Postgres credentials/db used by docker-compose. DATABASE_URL must match them
# (user:password@host:POSTGRES_HOST_PORT/db).
POSTGRES_USER=trimatch
POSTGRES_PASSWORD=trimatch
POSTGRES_DB=trimatch
DATABASE_URL=postgres://trimatch:trimatch@localhost:5432/trimatch
REDIS_URL=redis://localhost:6379

# Host ports published by docker-compose. Override both the port and the matching
# URL above if 5432/6379 are already taken on your machine.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# Auth — JWT signing secret (>=16 chars) and token lifetime.
JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_IN=8h

# Outbound notification delivery (Epic 9). `none` disables out-of-app delivery
# and the digest cleanly. `webhook` posts each digest to NOTIFICATIONS_WEBHOOK_URL
# and REQUIRES it — a partial config (webhook without a URL) fails the boot.
NOTIFICATIONS_CHANNEL=none
# NOTIFICATIONS_WEBHOOK_URL=https://hooks.example.com/notifications

# Rate limiting (Epic 16). Window in ms + max requests per IP per window. The
# auth pair is a stricter limit for credential endpoints (login). NOTE: running
# the full integration suite locally makes many requests/logins from one IP —
# raise these (see .env.ci) if you hit 429s in local tests.
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL=60000
THROTTLE_AUTH_LIMIT=5
