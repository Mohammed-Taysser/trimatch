# Copy to .env — the api validates these at startup and refuses to boot if invalid.
NODE_ENV=development
API_PORT=3000
DATABASE_URL=postgres://trimatch:trimatch@localhost:5432/trimatch
REDIS_URL=redis://localhost:6379

# Host ports published by docker-compose. Override both the port and the matching
# URL above if 5432/6379 are already taken on your machine.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
