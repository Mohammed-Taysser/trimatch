{
  "name": "trimatch",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "pnpm --filter @trimatch/shared build && pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @trimatch/shared build && pnpm -r test",
    "typecheck": "pnpm --filter @trimatch/shared build && pnpm -r typecheck"
  }
}
