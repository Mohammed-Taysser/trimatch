{
  "name": "trimatch",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "pnpm --filter @trimatch/shared build && pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @trimatch/shared build && pnpm -r test",
    "test:cov": "pnpm --filter @trimatch/shared build && pnpm -r test:cov",
    "test:integration": "pnpm --filter @trimatch/shared build && pnpm -r test:integration",
    "typecheck": "pnpm --filter @trimatch/shared build && pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.0",
    "typescript-eslint": "^8.25.0"
  }
}
