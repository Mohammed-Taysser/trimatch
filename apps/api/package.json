{
  "name": "@trimatch/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "test:cov": "jest --coverage",
    "test:integration": "jest -c jest.integration.config.cjs --passWithNoTests",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migration:new": "sequelize-cli migration:generate --name",
    "seed": "sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/sequelize": "^11.0.1",
    "@trimatch/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.0"
  }
}
